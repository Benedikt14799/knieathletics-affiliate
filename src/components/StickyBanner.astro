<!-- Sticky statt fixed: kein Spacer-Hack nötig, kein JS-Timing-Bug -->
<div id="sticky-banner" class="sticky top-0 z-[100] bg-blue-bayoux-700 text-white py-2 px-4 flex items-center justify-between gap-4 shadow-md text-sm">
  <div class="flex items-center gap-2 mx-auto">
    <span class="text-green-300 font-bold text-base">💸</span>
    <span class="font-semibold">200 € Cashback – nur über diese Seite</span>
    <a href="#erstberatung" class="hidden sm:inline-flex items-center bg-green-500 hover:bg-green-400 transition-colors text-white font-bold px-3 py-1 rounded-lg text-xs ml-2">
      Jetzt sichern →
    </a>
  </div>
  <button id="sticky-banner-close" aria-label="Banner schließen" class="text-white/70 hover:text-white transition-colors text-xl leading-none flex-shrink-0">✕</button>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var banner = document.getElementById('sticky-banner');
    var header = document.querySelector('header');

    function hideBanner() {
      if (banner) banner.style.display = 'none';
      // Header jetzt ganz oben sticky
      if (header) header.style.top = '0px';
      sessionStorage.setItem('sticky_banner_closed', '1');
    }

    if (sessionStorage.getItem('sticky_banner_closed')) {
      hideBanner();
    }

    var btn = document.getElementById('sticky-banner-close');
    if (btn) btn.addEventListener('click', hideBanner);
  });
</script>
