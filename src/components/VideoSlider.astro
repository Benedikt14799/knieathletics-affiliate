<section class="max-w-4xl mx-auto mb-16 px-4">
  <h2 class="text-2xl md:text-3xl font-extrabold text-blue-bayoux-950 mb-2 text-center">Das Programm in Aktion</h2>
  <p class="text-gray-500 text-center mb-8 text-sm">Einblick in den Aufbau und Inhalt von KNIEATHLETICS</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Slot 1: Echtes YouTube-Video -->
    <div class="flex flex-col gap-2">
      <div class="relative w-full aspect-video rounded-xl overflow-hidden shadow-md bg-gray-900">
        <iframe
          src="https://www.youtube-nocookie.com/embed/DIk_ctMzoVY?rel=0&modestbranding=1"
          title="KNIEATHLETICS – Programm-Einblick"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          class="absolute inset-0 w-full h-full border-0"
        ></iframe>
      </div>
      <p class="text-xs text-gray-400 text-center">Video von KNIEATHLETICS</p>
    </div>

    <!-- Slot 2: youtube.com/watch?v=BlTssyYLC5Y -->
