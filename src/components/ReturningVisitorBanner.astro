<div id="returning-visitor-banner" class="hidden mb-6 bg-amber-50 border border-amber-300 rounded-2xl px-5 py-4 flex items-center justify-between gap-4 shadow-sm">
  <div class="flex items-center gap-3">
    <span class="text-2xl">👋</span>
    <div>
      <p class="font-bold text-amber-900 text-sm">Willkommen zurück!</p>
      <p class="text-amber-700 text-sm">Dein 200 € Cashback wartet noch auf dich.</p>
    </div>
  </div>
  <a href="#erstberatung" class="bg-amber-500 hover:bg-amber-600 transition-colors text-white font-bold px-4 py-2 rounded-lg text-sm whitespace-nowrap flex-shrink-0">
    Jetzt sichern →
  </a>
</div>

<script is:inline>
  (function() {
    const key = 'knia_visited';
    const banner = document.getElementById('returning-visitor-banner');
    if (localStorage.getItem(key)) {
      banner.classList.remove('hidden');
      banner.classList.add('flex');
    } else {
      localStorage.setItem(key, '1');
    }
  })();
</script>
