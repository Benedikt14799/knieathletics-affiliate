---
import AffiliateLayout from '../../layouts/AffiliateLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import CTAButton from '../../components/CTAButton.astro';

const faqs = [
  { question: "Ist die Erstberatung wirklich kostenlos?", answer: "Ja, vollständig. Es ist kein Verkaufsgespräch und es gibt keine versteckten Kosten." },
  { question: "Wie funktioniert der 200 € Cashback genau?", answer: "Ganz einfach: Sende mir nach deinem Programmstart die Buchungsbestätigung an meine E-Mail-Adresse. Ich überweise dir daraufhin 200 € direkt auf dein Konto. Kein Code, kein Marketing-Trick." },
  { question: "Für wen ist das NICHT geeignet?", answer: "Für Patienten mit einer akuten OP-Notwendigkeit oder chronischen Blockaden, die manuell in der Praxis gelöst werden müssen. Ob dies der Fall ist, erfährst du auch in der Erstberatung." }
];

const schemaData = {
  "@context": "https://schema.org/",
  "@graph": [
    {
      "@type": "WebPage",
      "name": "Knie-Reha online – strukturiert zurück in den Alltag und Sport",
      "description": "Meine persönliche Erfahrung mit KNIEATHLETICS + 200 € Cashback wenn du über mich buchst"
    },
    {
      "@type": "Offer",
      "name": "200 € Cashback bei Buchung über Benedikt Faude",
      "description": "Persönlicher Cashback von 200 € bei Buchung des KNIEATHLETICS-Programms über diese Seite.",
      "seller": {
        "@type": "Person",
        "name": "Benedikt Faude"
      },
      "price": "200",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    },
    {
      "@type": "Person",
      "name": "Benedikt Faude",
      "url": "https://benediktfau.de"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  ]
};
---

<AffiliateLayout 
  title="Knie-Reha online – strukturiert zurück in den Sport (+200€ Cashback)" 
  description="Meine persönliche Erfahrung mit dem KNIEATHLETICS Reha-Programm. Profitiere von meinem Testbericht und 200 € Cashback bei Buchung."
  canonical="https://benediktfau.de/knieathletics/"
  schemaType="WebPage"
  schemaData={schemaData}
>

  <!-- SEKTION 1: HERO -->
  <section class="mb-16 text-center pt-4" onmouseenter="if(typeof gtag !== 'undefined' && !window.offerTracked) { window.offerTracked = true; gtag('event', 'cashback_banner_viewed'); }">
    <div class="inline-flex items-center text-blue-bayoux-800 text-sm font-bold px-3 py-1 rounded-full mb-6 bg-blue-100 border border-blue-200 shadow-sm">
      Aktueller Erfahrungsbericht 2026
    </div>
    
    <h1 class="text-4xl md:text-5xl lg:text-5xl font-extrabold text-blue-bayoux-950 mb-6 tracking-tight leading-tight">
      Knie-Reha online –<br class="hidden md:block"/> strukturiert zurück in den Sport
    </h1>
    
    <p class="text-xl md:text-2xl text-gray-600 font-medium mb-8 max-w-3xl mx-auto leading-relaxed">
      Meine persönliche Erfahrung mit KNIEATHLETICS<br/>
      <span class="text-green-600 font-bold">+ 200 € Cashback</span> wenn du über meine Seite ins Programm kommst
    </p>

    <!-- PFLICHT: Echtes Foto von Benedikt (Placeholder) -->
    <div class="w-48 h-48 mx-auto mb-8 bg-gray-200 rounded-full overflow-hidden border-4 border-white shadow-lg flex items-center justify-center">
      <img src="/benedikt-portrait.jpg" alt="Benedikt Faude" class="w-full h-full object-cover" style="object-position: 50% 25%;" onerror="this.src='https://placehold.co/400x400/e2e8f0/64748b?text=Foto'" />
    </div>

    <!-- Cashback Banner -->
    <div class="bg-green-50 border-2 border-green-500 rounded-2xl p-6 md:p-8 max-w-2xl mx-auto mb-10 shadow-md">
      <h2 class="text-2xl font-bold text-green-800 mb-4 flex flex-col items-center justify-center text-center">
         <span class="text-3xl mb-2">🎁</span> 
         <span>Mein persönlicher Bonus:<br/><span class="text-green-700">200 € Cashback für dich</span></span>
      </h2>
      <p class="text-green-700 font-medium text-lg leading-relaxed">
        Wenn du über meine Seite ins Programm kommst, erstatte ich dir persönlich 200 € zurück – direkt nach Programmstart.
      </p>
    </div>

    <div class="flex justify-center">
      <CTAButton href="#erstberatung" text="Gratis Erstgespräch bei KNIEATHLETICS anfragen + 200 € sichern" class="text-lg py-4 px-8" />
    </div>
  </section>


  <!-- SEKTION 2: TRUST-SIGNAL-LEISTE -->
  <section class="border border-gray-200 py-3 md:py-4 mb-16 bg-white shadow-sm rounded-xl px-3 md:px-5 w-full">
    <div class="flex flex-row flex-wrap sm:flex-nowrap justify-center sm:justify-between items-center gap-3 md:gap-4 text-[11.5px] lg:text-[13px] font-semibold text-blue-bayoux-800">
      <div class="flex items-center whitespace-nowrap"><span class="text-sm lg:text-base mr-1.5 md:mr-2">✅</span> Selbst verletzt & genesen</div>
      <div class="flex items-center whitespace-nowrap"><span class="text-sm lg:text-base mr-1.5 md:mr-2">📅</span> Erfahrungsbericht seit 2024</div>
      <div class="flex items-center whitespace-nowrap"><span class="text-sm lg:text-base mr-1.5 md:mr-2">💸</span> 200 € Cashback für dich</div>
      <div class="flex items-center whitespace-nowrap"><span class="text-sm lg:text-base mr-1.5 md:mr-2">🔒</span> Keine versteckten Kosten</div>
    </div>
  </section>


  <!-- SEKTION 3: KERNFRAGE BEANTWORTEN -->
  <section class="max-w-3xl mx-auto mb-16 px-4">
    <h2 class="text-3xl md:text-4xl font-extrabold text-blue-bayoux-950 mb-6">Funktioniert Knie-Reha wirklich online?<br></h2>
    <div class="prose prose-blue prose-lg text-gray-700 max-w-none">
      <p class="font-bold text-xl text-blue-bayoux-800">Knieathletics ist kein allgemeines Physio-Programm.</p>
      
      <p><br>Sie sind ausschließlich auf Knie spezialisiert – und genau das macht den Unterschied. Sie haben über 1.240 Knieverletzungen betreut. Ausschließlich Knie. Kein anderes Körperteil.</p>

      <p><br>Das Programm ist gemacht für Menschen mit Kreuzbandriss, Meniskusriss oder chronischen Kniebeschwerden – die mehr wollen als Standardversorgung. Mehr als 2 x 20min Physio pro Woche.</p>
      
      <p><br>Das Programm ist für den langfristigen Wiedereinstieg in Alltag und Sport gemacht. Somit NICHT geeignet wenn du akute ärztliche Notfallversorgung brauchst. <br><br>Für alle anderen: Das gratis Erstgespräch bei Knieathletics zeigt dir, ob und wie sie dir helfen können.</p>
      
      <p class="text-xl font-medium text-blue-bayoux-900 mt-8 italic border-l-4 border-blue-bayoux-500 pl-4">
        Ich war skeptisch – also hab ich's selbst getestet:
      </p>
    </div>
  </section>


  <!-- SEKTION 4: BENEDIKTS GESCHICHTE (Timeline) -->
  <section class="bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-gray-100 max-w-4xl mx-auto mb-16">
    <div class="flex flex-col md:flex-row gap-10 items-center mb-8">
      <div class="w-32 h-32 md:w-48 md:h-48 shrink-0 bg-gray-200 rounded-full overflow-hidden border-4 border-blue-bayoux-100 flex items-center justify-center">
        <img src="/benedikt-ski.jpg" alt="Benedikt beim Skifahren" class="w-full h-full object-cover" style="object-position: 50% 100%;" onerror="this.src='https://placehold.co/400x400/e2e8f0/64748b?text=Foto'" />
      </div>
      <div>
        <h2 class="text-3xl font-extrabold text-blue-bayoux-950 mb-4">Meine Erfahrung mit Knieathletics</h2>
        <div class="space-y-4">
          <div class="flex flex-col sm:flex-row sm:gap-4">
            <div class="w-40 font-bold text-gray-500 shrink-0 mb-1 sm:mb-0">Vorher:</div>
            <div class="text-gray-800 font-medium">Schmerzen nach jeder Belastung. Sport? Undenkbar.</div>
          </div>
          <div class="flex flex-col sm:flex-row sm:gap-4">
            <div class="w-40 font-bold text-gray-500 shrink-0 mb-1 sm:mb-0">Woche 8:</div>
            <div class="text-gray-800 font-medium">Zum ersten Mal seit Monaten denke ich nicht mehr ans Knie – weil es sich nicht mehr belastet anfühlt.</div>
          </div>
          <div class="flex flex-col sm:flex-row sm:gap-4">
            <div class="w-40 font-bold text-blue-bayoux-600 shrink-0 mb-1 sm:mb-0">Woche 12:</div>
            <div class="text-gray-800 font-medium">Spürbar mehr Kraft. Skitouren, Radfahren, Wandern – wieder dabei.</div>
          </div>
          <div class="flex flex-col sm:flex-row sm:gap-4">
            <div class="w-40 font-bold text-green-600 shrink-0 mb-1 sm:mb-0">Heute:</div>
            <div class="text-gray-800 font-bold"> Die Kraftwerte stimmen, als nächstes folgt der Wiedereinstieg ins Joggen!</div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="text-center md:text-left mt-6">
      <a href="/knie athletics/erfahrungsbericht" class="text-blue-bayoux-700 font-bold hover:text-blue-bayoux-900 transition-colors inline-flex items-center text-lg">
        Meinen ganzen Erfahrungsbericht lesen <span class="ml-2">→</span>
      </a>
    </div>
  </section>


  <!-- SEKTION 5: LEAD-FORMULAR -->
  <section class="max-w-3xl mx-auto mb-16 px-4">
    <h2 class="sr-only">Gratis Erstgespräch bei KNIEATHLETICS anfragen + 200 € Cashback vormerken</h2>
    <LeadForm />
  </section>


  <!-- SEKTION 6: 3 FAQ -->
  <section class="max-w-3xl mx-auto mb-20 px-4">
    <h2 class="text-3xl font-extrabold text-blue-bayoux-950 mb-8 text-center border-b-2 border-gray-100 pb-4">Die 3 wichtigsten Fragen</h2>
    
    <div class="space-y-4">
      {faqs.map((faq, index) => (
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-bold text-lg text-blue-bayoux-900 hover:bg-gray-50 transition-colors">
            {faq.question}
            <span class="transition duration-300 group-open:-rotate-180">
              <svg fill="none" class="w-6 h-6 text-blue-bayoux-500" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-gray-700 leading-relaxed border-t border-gray-50 mt-2">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
    
    <div class="text-center mt-8">
      <a href="/knieathletics/faq" class="text-blue-bayoux-600 hover:text-blue-bayoux-800 font-bold inline-flex items-center text-sm uppercase tracking-wider">
        Alle 11 Fragen & Antworten ansehen <span class="ml-2">→</span>
      </a>
    </div>
  </section>


  <!-- SEKTION 7: FINALER CTA -->
  <section class="bg-blue-bayoux-900 text-white rounded-3xl p-10 md:p-16 text-center max-w-4xl mx-auto shadow-xl relative overflow-hidden mb-10 mx-4">
    <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    
    <div class="relative z-10">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-6">Bereit? Starte jetzt kostenlos.</h2>
      <p class="text-xl text-blue-bayoux-200 mb-10 max-w-2xl mx-auto">Sichere dir das gratis Erstgespräch bei KNIEATHLETICS, blockiere dir den Cashback-Bonus und finde heraus, ob der Plan zu deiner Verletzung passt.</p>
      
      <div class="flex justify-center">
        <CTAButton href="#erstberatung" text="Gratis Erstgespräch bei KNIEATHLETICS anfragen + 200 € sichern" variant="primary" class="bg-green-500 hover:bg-green-600 border-none text-white text-lg py-5 px-10" />
      </div>
    </div>
  </section>

</AffiliateLayout>
